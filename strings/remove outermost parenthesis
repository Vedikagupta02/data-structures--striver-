class Solution {
public:
    string removeOuterParentheses(string s) {

        int n=s.size();
        int counter=0;
        string res="";
        for(char ch: s){
            if(ch=='('){
                counter++;
                if(counter>1){
                    res+=ch;
                }
            }
            else{
                counter--;
                if(counter>0){
                    res+=ch;
                }
            }
        }
        return res;
        
    }
};
